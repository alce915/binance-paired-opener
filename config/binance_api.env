# Binance multi-account credentials template
# 公开仓库仅保留模板，请在本机私有环境中填写真实值
BINANCE_ACCOUNTS=main,sub1,sub2

# 账户 1
BINANCE_ACCOUNT_MAIN_NAME=主账户的子账户1
BINANCE_ACCOUNT_MAIN_API_KEY=
BINANCE_ACCOUNT_MAIN_API_SECRET=
BINANCE_ACCOUNT_MAIN_USE_TESTNET=false

# 账户 2
BINANCE_ACCOUNT_SUB1_NAME=主账户的子账户2
BINANCE_ACCOUNT_SUB1_API_KEY=
BINANCE_ACCOUNT_SUB1_API_SECRET=
BINANCE_ACCOUNT_SUB1_USE_TESTNET=false

# 账户 3
BINANCE_ACCOUNT_SUB2_NAME=主账户的子账户3
BINANCE_ACCOUNT_SUB2_API_KEY=
